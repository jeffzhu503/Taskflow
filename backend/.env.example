# Copy this file to .env and fill in your values.
# Required PAT scopes: repo (classic) OR fine-grained: Issues RW, Pull requests RW, Metadata R
GITHUB_PAT=your_github_personal_access_token_here

# OpenTelemetry — point at your OTel Collector's OTLP HTTP receiver (default port 4318)
OTEL_ENABLED=true
OTEL_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=taskflow-backend
